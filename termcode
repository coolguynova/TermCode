#!/usr/bin/env bash
# Run TermCode using the virtual environment
# Resolve symlink to get the actual directory of this script
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
DIR="$( cd -P "$( dirname "$SOURCE" )" && pwd )"

if [ -d "$DIR/.venv" ]; then
    source "$DIR/.venv/bin/activate"
fi
python "$DIR/main.py" "$@"
